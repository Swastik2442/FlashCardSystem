{
  "name": "flashcardsystem",
  "version": "1.2.2",
  "private": true,
  "author": "Swastik Kulshreshtha",
  "license": "MIT",
  "description": "The Full-Stack Project of a Flash Card Learning System.",
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev": "pnpm -r --parallel dev",
    "dev:with-db": "pnpm docker:up && pnpm run dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test:server": "pnpm --filter server test",
    "test:with-db": "pnpm docker:up && pnpm test:server && pnpm docker:down"
  }
}
